# =============================================================================
# PropOS environment variables template
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (admin authentication)
# Get these from https://dashboard.clerk.com or the Vercel Marketplace Clerk
# integration (auto-provisions both keys into your Vercel project).
# Sign-ups should be disabled in the Clerk dashboard: admin is invite-only.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Optional Clerk routing overrides (defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# -----------------------------------------------------------------------------
# Supabase (tenant portal auth, database)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@example.com

# -----------------------------------------------------------------------------
# Twilio (SMS)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Anthropic (Claude API for in-app AI features)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Misc server secrets
# ADMIN_SECRET  — legacy admin guard; kept until Clerk fully rolls out
# CRON_SECRET   — shared secret for /api/cron/* requests from Vercel Cron
# -----------------------------------------------------------------------------
ADMIN_SECRET=
CRON_SECRET=
