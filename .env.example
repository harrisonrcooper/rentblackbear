# =============================================================================
# PropOS environment variables template
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Admin gate (shared-password authentication)
# There are no user accounts: anyone who knows ADMIN_PASSWORD signs in as the
# single principal ADMIN_USER_ID. See lib/auth.ts.
# -----------------------------------------------------------------------------
# The password for /admin.
ADMIN_PASSWORD=
# HMAC key for the session cookie. Generate with: openssl rand -hex 32
# Must be >= 32 chars. Rotating it invalidates every live session.
ADMIN_SESSION_SECRET=
# The principal id every signed-in caller runs as. Workspace-scoped data
# (budget:<id> blobs, storage paths, profiles.clerk_user_id) is keyed on it,
# so changing this value orphans that data. Keep it stable.
ADMIN_USER_ID=

# -----------------------------------------------------------------------------
# Supabase (tenant portal auth, database)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@example.com

# -----------------------------------------------------------------------------
# Twilio (SMS)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Anthropic (Claude API for in-app AI features)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Misc server secrets
# ADMIN_SECRET  — legacy, unreferenced in code; safe to drop
# CRON_SECRET   — shared secret for /api/cron/* requests from Vercel Cron
# -----------------------------------------------------------------------------
ADMIN_SECRET=
CRON_SECRET=
